{
  "name": "reuse-canada-crm",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name reuse-canada-scale --branch main --commit-dirty=true",
    "dev:sandbox": "wrangler pages dev dist --d1=reuse-canada-production --local --ip 0.0.0.0 --port 3000",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply reuse-canada-production --local",
    "db:seed": "wrangler d1 execute reuse-canada-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console": "wrangler d1 execute reuse-canada-production --local"
  },
  "dependencies": {
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "playwright": "^1.58.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
